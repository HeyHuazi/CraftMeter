{
  "id": "dragoncode",
  "displayName": "dragoncode.codes",
  "match": {
    "hostPatterns": ["dragoncode.codes"],
    "defaultDisplayName": "dragoncode.codes",
    "defaultTokenChannelEnabled": false,
    "defaultBalanceChannelEnabled": true
  },
  "setup": {
    "recommendedBaseURL": "https://dragoncode.codes",
    "requiredInputs": ["balanceAuth"],
    "balanceAuthHint": {
      "zhHans": "粘贴请求头中的 Authorization 值（支持 Bearer 前缀或原始 Token）。",
      "en": "Paste the Authorization value from request headers (with or without the Bearer prefix)."
    }
  },
  "authStrategies": [
    { "kind": "savedBearer" },
    { "kind": "browserBearer" }
  ],
  "balanceRequest": {
    "method": "GET",
    "path": "/api/v1/auth/me",
    "authHeader": "Authorization",
    "authScheme": "Bearer"
  },
  "extract": {
    "remaining": "data.balance",
    "unit": "balance"
  }
}
