{
  "id": "hongmacc",
  "displayName": "hongmacc.com",
  "match": {
    "hostPatterns": ["hongmacc.com"],
    "defaultDisplayName": "hongmacc.com",
    "defaultTokenChannelEnabled": false,
    "defaultBalanceChannelEnabled": true
  },
  "setup": {
    "recommendedBaseURL": "https://hongmacc.com",
    "requiredInputs": ["balanceAuth"],
    "balanceAuthHint": {
      "zhHans": "粘贴请求头中的 Authorization Bearer 值。",
      "en": "Paste the Authorization bearer value from request headers."
    }
  },
  "authStrategies": [
    { "kind": "savedBearer" },
    { "kind": "browserBearer" }
  ],
  "balanceRequest": {
    "method": "GET",
    "path": "/api/user/assets",
    "authHeader": "Authorization",
    "authScheme": "Bearer"
  },
  "extract": {
    "remaining": "sum(quotaCards.*.remainingQuota)",
    "unit": "CNY"
  }
}
